{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0",
    "moduleResolution": "nodenext"
  }
}
